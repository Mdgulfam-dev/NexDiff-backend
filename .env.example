# PORT=5001
# MONGODB_URI=
# ADMIN_TOKEN_SECRET=

# # Fallback/bootstrap dashboard logins.
# # After login as Admin, create/update users from Admin Dashboard > Users.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# EXECUTIVE_USERNAME=
# EXECUTIVE_PASSWORD=
# MANAGER_USERNAME=
# MANAGER_PASSWORD=

# # Email delivery.
# # SendGrid is tried first when SENDGRID_API_KEY is set.
# # SENDGRID_FROM must be a verified Sender Identity in SendGrid.
# SENDGRID_API_KEY=
# SENDGRID_FROM="NexDiff <verified-sender@example.com>"

# # SMTP fallback email.
# # Used only when SendGrid is not configured or SendGrid sending fails.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="NexDiff <fallback-smtp-sender@example.com>"

# # Internal notifications.
# # Customer/applicant confirmation is sent when the submitted email is valid.
# # Hiring notification is sent to CAREERS_NOTIFY_EMAIL.
# SEND_INTERNAL_NOTIFY_EMAILS=false
# CAREERS_NOTIFY_EMAIL=
# PLAN_REQUEST_NOTIFY_EMAIL=
